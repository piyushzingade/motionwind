{
  "name": "motionwind-react-native",
  "version": "0.1.0",
  "description": "Motionwind for React Native — animate with Tailwind-like classes using Reanimated",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./parser": {
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs",
      "types": "./dist/parser.d.ts"
    },
    "./babel": {
      "import": "./dist/babel.js",
      "require": "./dist/babel.cjs",
      "types": "./dist/babel.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": "^3.0.0 || ^4.0.0",
    "nativewind": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "nativewind": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "react-native-reanimated": "^3.16.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "keywords": [
    "react-native",
    "animation",
    "tailwindcss",
    "nativewind",
    "reanimated",
    "motionwind",
    "motion"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/piyushzingade/motionwind.git",
    "directory": "packages/motionwind-react-native"
  },
  "publishConfig": {
    "access": "public"
  }
}
